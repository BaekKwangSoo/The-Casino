# ── 환경 설정 (.env.example → .env 복사 후 값 입력) ──

# 서버
NODE_ENV=production

# 데이터베이스
DB_NAME=casino_db
DB_USER=casino_user
DB_PASSWORD=your_strong_password_here

# Redis
REDIS_PASSWORD=your_redis_password_here

# JWT (openssl rand -hex 32 로 생성)
JWT_SECRET=your_jwt_secret_here

# 프론트엔드에서 접속할 URL (EC2 퍼블릭 IP 또는 도메인)
VITE_API_URL=http://your-ec2-ip-or-domain
VITE_SOCKET_URL=http://your-ec2-ip-or-domain

# CORS 허용 도메인
CORS_ORIGIN=http://your-ec2-ip-or-domain
